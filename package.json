{
  "name": "@kunver/new",
  "version": "3.8.1",
  "description": "Opinionated project starter",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "kunver": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "pnpm run build && pnpm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm run build",
    "local": "pnpm run build && pnpm link --global",
    "manager": "node manager.cjs pnpm",
    "patch": "pnpm version patch && git push",
    "minor": "pnpm version minor && git push",
    "major": "pnpm version major && git push",
    "patch-publish": "pnpm run patch && pnpm run manager publish",
    "minor-publish": "pnpm run minor && pnpm run manager publish",
    "major-publish": "pnpm run major && pnpm run manager publish"
  },
  "keywords": [
    "project starter",
    "cli",
    "template",
    "opinionated"
  ],
  "author": "Burak Unver <burakhanunver@gmail.com> (https://kunver.dev)",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "prettier": "3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
